# SAP Router Orchestrator — Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# This file is safe to commit (no secrets).
# .env is in .gitignore — never commit it.

# === REQUIRED: ARC-1 ADT Primary MCP ===
# SAP S/4HANA system URL with ADT port
ARC_SAP_URL=https://your-s4hana.example.com:44300
# SAP user with S_DEVELOP + S_ADT_RES roles
ARC_SAP_USER=DEVELOPER
# SAP password (never commit to git)
ARC_SAP_PASSWORD=
# SAP client number
ARC_SAP_CLIENT=100

# === OPTIONAL: TypeScript ADT MCP ===
SAP_URL=https://your-s4hana.example.com:44300
SAP_USERNAME=DEVELOPER
SAP_PASSWORD=
SAP_CLIENT=100

# === OPTIONAL: SAP GUI Scripting (ADT fallback) ===
SAPGUI_HOST=your-s4hana.example.com
SAPGUI_USER=DEVELOPER
SAPGUI_PASSWORD=
SAPGUI_CLIENT=100
SAP_CONNECTION=/H/your-s4hana/S/3200

# === OPTIONAL: SAP RFC MCP (ZROUTER dispatch) ===
SAP_RFC_HOST=your-s4hana.example.com
SAP_RFC_USER=DEVELOPER
SAP_RFC_PASSWORD=
SAP_RFC_CLIENT=100

# === OPTIONAL: SuccessFactors MCP (HCM cloud) ===
