# SAP Router Orchestrator — Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# This file is safe to commit (no secrets).
# .env is in .gitignore — never commit it.

# === REQUIRED: ARC-1 ADT Primary MCP ===
# SAP S/4HANA system URL with ADT port
ARC_SAP_URL=https://your-s4hana.example.com:44300
# SAP user with S_DEVELOP + S_ADT_RES roles
ARC_SAP_USER=DEVELOPER
# SAP password (never commit to git)
ARC_SAP_PASSWORD=
# SAP client number
ARC_SAP_CLIENT=100

# === OPTIONAL: TypeScript ADT MCP ===
SAP_URL=https://your-s4hana.example.com:44300
SAP_USERNAME=DEVELOPER
SAP_PASSWORD=
SAP_CLIENT=100

# === OPTIONAL: SAP GUI Scripting (ADT fallback) ===
SAPGUI_HOST=your-s4hana.example.com
SAPGUI_USER=DEVELOPER
SAPGUI_PASSWORD=
SAPGUI_CLIENT=100
SAP_CONNECTION=/H/your-s4hana/S/3200

# === OPTIONAL: SAP RFC MCP (ZROUTER dispatch) ===
SAP_RFC_HOST=your-s4hana.example.com
SAP_RFC_USER=DEVELOPER
SAP_RFC_PASSWORD=
SAP_RFC_CLIENT=100

# === OPTIONAL: SuccessFactors MCP (HCM cloud) ===
SF_URL=https://your-instance.successfactors.com
SF_USERNAME=sf-api-user@example.com
SF_PASSWORD=

# === OPTIONAL: SAP Cloud Integration (CPI) MCP ===
CPI_HOST=https://your-tenant.it-cpi001.cfapps.eu10.hana.ondemand.com
CPI_USER=your-cpi-user@example.com
CPI_PASSWORD=

# === OPTIONAL: Cloud Foundry MCP (BTP CF Runtime) ===
CF_API=https://api.cf.us10.hana.ondemand.com
CF_USER=your-btp-user@example.com
CF_PASSWORD=

# === OPTIONAL: SAP API Management MCP ===
APIM_HOST=https://your-apim-tenant.apimanagement.eu10.hana.ondemand.com
APIM_USER=your-apim-user@example.com
APIM_PASSWORD=

# === OPTIONAL: SAP PI/PO (legacy integration) ===
