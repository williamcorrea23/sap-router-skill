{
  "name": "sap-transport-mcp",
  "version": "0.1.3",
  "description": "MCP server for SAP Change and Transport System (CTS) — governed, auditable transport management via Claude",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "sap-transport-mcp": "dist/src/index.js"
  },
  "files": [
    "dist/",
    "scripts/",
    ".env.example",
    ".mcp.example.json"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "preflight": "node scripts/preflight.js",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tools config lib --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "fast-xml-parser": "^4.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
