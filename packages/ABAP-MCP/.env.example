# ============================================================
# ABAP MCP Server v2 — Konfiguration
# ============================================================

# ── SAP-Systemverbindung (Pflicht) ─────────────────────────
SAP_URL=https://ihr-sap-system:44300
SAP_USER=DEVELOPER
SAP_PASSWORD=IhrPasswort
SAP_CLIENT=100
SAP_LANGUAGE=DE

# ── Schreibschutz ──────────────────────────────────────────
# ALLOW_WRITE=true  → Schreib-Tools aktiviert (nur DEV-System!)
# ALLOW_WRITE=false → Read-only Modus (sicher für alle Systeme)
ALLOW_WRITE=false

# ALLOW_DELETE=true → delete_abap_object aktiviert. Nur wirksam wenn ALLOW_WRITE=true.
ALLOW_DELETE=false

# ALLOW_EXECUTE=true → execute_abap_snippet aktiviert (temporären ABAP-Code ausführen).
# Erfordert zusätzlich ALLOW_WRITE=true.
ALLOW_EXECUTE=false

# Kommaliste gesperrter Paket-Präfixe — KI kann NICHT in diese Pakete schreiben.
BLOCKED_PACKAGES=SAP,SHD,SMOD

# ── Governance (Rollen & Audit) ────────────────────────────
# SAP_ROLE schränkt zusätzlich zu den ALLOW_*-Flags ein (kann nur weiter
# einschränken, nie freischalten):
#   viewer    → nur lesen (blockiert write/delete/execute trotz ALLOW_*)
#   developer → write + execute (kein delete)
#   admin     → alles (Default; ALLOW_*-Flags bleiben die einzige Schranke = bisheriges Verhalten)
SAP_ROLE=admin

# Optional: Pfad für ein JSON-Audit-Log aller verändernden Aktionen.
# Audit-Zeilen gehen immer zusätzlich nach STDERR (Präfix "AUDIT ").
# AUDIT_LOG_FILE=/abs/path/to/abap-mcp-audit.log

# Standard-Transport wenn keiner angegeben. Leer lassen für lokale Objekte ($TMP).
DEFAULT_TRANSPORT=

# Syntaxcheck vor Aktivierung erzwingen (empfohlen: true).
SYNTAX_CHECK_BEFORE_ACTIVATE=true

# ── SSL/TLS ────────────────────────────────────────────────
# Selbstsignierte Zertifikate erlauben (nur DEV-Systeme!).
# SAP_ALLOW_UNAUTHORIZED=true

# ============================================================
#  Netzwerk-Routing — genau EINE Variante aktivieren.
#  Reihenfolge der Auswahl im Server: BTP → SAProuter → Proxy → direkt.
# ============================================================

# ── Variante A: SAP BTP Connectivity Proxy ──────────────────
# Empfohlen für hybride CAP-Entwicklung. Der Server tunnelt durch den lokal
# weitergeleiteten Connectivity Proxy einer CF-App, die das `connectivity`-
# Service gebunden hat. Vorbereitung pro Session:
#
#   cf ssh <app> -N -L 20003:connectivityproxy.internal.cf.<region>.hana.ondemand.com:20003
#
# Konfiguration:
#   SAP_BTP_CONNECTIVITY_PROXY=http://localhost:20003
#   SAP_BTP_CONNECTIVITY_LOCATION_ID=         # leer = Default-Cloud-Connector
#   SAP_BTP_CONNECTIVITY_DEBUG=false
#
# JWT-Quelle (eine von drei reicht):
#
#  1) Pre-fetched service-key JSON
#       SAP_BTP_CONNECTIVITY_CREDS_FILE=/abs/path/to/creds.json
#
#  2) CAP-Projekt-Binding (`cds bind --for hybrid`)
#       SAP_BTP_CONNECTIVITY_CDS_BIND_FILE=/abs/path/to/<project>/.cdsrc-private.json
#       SAP_BTP_CONNECTIVITY_CDS_BIND_NAME=connectivity
#       SAP_BTP_CF_HOME=/abs/path/to/<project>     # optional, eigene CF-Session
#
#  3) Direkte Umgebungsvariablen
#       SAP_BTP_CONNECTIVITY_CLIENT_ID=
#       SAP_BTP_CONNECTIVITY_CLIENT_SECRET=
#       SAP_BTP_CONNECTIVITY_TOKEN_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com
#
# SAP_URL bei BTP-Variante:
#   - Port 20003 (HTTP forward proxy) → SAP_URL muss `http://...` sein.
#     Cloud Connector übernimmt die Backend-TLS.
#       z.B. SAP_URL=http://mdadneap1.example.com:44300
#   - Port 20004 (HTTPS CONNECT)      → SAP_URL kann `https://...` sein.
#
# Hinweis: Im Cloud Connector muss `/sap/bc/adt/*` als Resource freigegeben sein.

# ── Variante B: SAProuter NI-Tunnel (klassische B2B-VPN) ────
# Wenn SAP-Hosts nur über einen SAProuter erreichbar sind. Der Server spricht
# das SAP-NI-Protokoll mit dem Router und tunnelt HTTPS-Traffic ans Backend.
#
#   Form 1 (SAP-Routestring): /H/saproutprd.example.com/S/3299[/W/password]
#   Form 2 (kurz):            saproutprd.example.com:3299
#
# SAP_ROUTER=/H/saproutprd.example.com/S/3299
# SAP_ROUTER_PASSWORD=
# SAP_ROUTER_DEBUG=false

# ── Variante C: Generischer HTTP-CONNECT-Proxy ──────────────
# Corporate-Proxy oder lokaler SSH-/socat-Tunnel.
#   SAP_PROXY_URL=http://proxy.corp.example.com:8080
#   SAP_PROXY_URL=http://localhost:8443
# Standard-Env-Variablen HTTPS_PROXY / HTTP_PROXY werden ebenfalls honoriert.
#
# WICHTIG: SAProuter-Routes (/H/.../S/...) gehören NICHT in SAP_URL oder
# SAP_PROXY_URL — siehe Variante B.

# ============================================================
#  Diagnose / Sonstiges
# ============================================================

# Maximale Anzahl Short Dumps bei get_short_dumps.
MAX_DUMPS=20

# DEFER_TOOLS=true  → Nur Kern-Tools initial laden, Rest on-demand (spart Tokens).
# DEFER_TOOLS=false → Alle Tools sofort laden (Legacy-Modus).
DEFER_TOOLS=true

# ABAP-Version für help.sap.com Dokumentation (z.B. "latest", "758", "754").
SAP_ABAP_VERSION=latest

# Source-Cache: TTL in Millisekunden für getObjectSource-Ergebnisse.
# Wiederholte Reads desselben Objekts werden gecached; Writes/Deletes
# invalidieren automatisch. 0 = Cache aus. Default 30000 (30 s).
# SOURCE_CACHE_TTL_MS=30000

# Tavily API-Key für `fetch_url` und `search_sap_web` — Sign-up: https://tavily.com (Free-Tier).
# fetch_url: Liest Inhalte beliebiger URLs (auch SPAs wie SAP Help Portal)
# search_sap_web: Durchsucht SAP Help, Community & Notes
TAVILY_API_KEY=

# TLS-Zertifikatsprüfung NUR für Web-Calls (fetch_url/search_sap_web) deaktivieren —
# für Corporate-Proxies, die TLS mit eigenen Zertifikaten aufbrechen.
# Bewusst getrennt von SAP_ALLOW_UNAUTHORIZED (gilt nur für die ADT-Verbindung).
# WEB_ALLOW_UNAUTHORIZED=false
