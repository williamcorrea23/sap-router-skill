# ─── Copy to .env (git-ignored) and fill in before running calm-mcp ─

# Mode: "oauth2" (live tenant) or "sandbox" (SAP API Business Hub).
CALM_MODE=

# ─── OAuth2 mode (when CALM_MODE=oauth2) ────────────────────────────────────
# Tenant base URL for Cloud ALM APIs — paste endpoints.Api from your
# XSUAA service-key VERBATIM, including the /api suffix. The connection
# appends service routes by plain concatenation and does NOT inject /api.
#   Example:  https://eu10-004.alm.cloud.sap/api
#   Regions:  eu10, eu20, us10, ap10, jp10, ca10, eu11, cn20
CALM_BASE_URL=

# XSUAA client_credentials — copy from your service key JSON:
#   "uaa": { "url": …, "clientid": …, "clientsecret": … }
CALM_UAA_URL=
CALM_UAA_CLIENT_ID=
CALM_UAA_CLIENT_SECRET=

# ─── Sandbox mode (when CALM_MODE=sandbox) ──────────────────────────────────
# Default base URL is https://sandbox.api.sap.com/SAPCALM — uncomment to override.
# CALM_BASE_URL=https://sandbox.api.sap.com/SAPCALM

# API key from https://api.sap.com/ → SAPCALM sandbox → Show API Key.
CALM_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────
# HTTP timeout in ms (default 30000).
# CALM_TIMEOUT=60000

# ─── Auth flow choice (optional, default: client_credentials) ───────────────
# CALM_AUTH_FLOW=client_credentials  # service-binding sb-* clients, no browser
# CALM_AUTH_FLOW=authorization_code  # user-scope, needs DEFAULT.env from mcp-auth

# ─── Destination name (optional, default: DEFAULT) ─────────────────────────
# Maps to ./{CALM_DESTINATION}.env file consumed by auth-broker.
# CALM_DESTINATION=DEFAULT

# ─── Generating ./DEFAULT.env from a BTP service key ───────────────────────
# Once with a service key downloaded from BTP cockpit:
#   npx mcp-auth --service-key ./sk.json --output ./DEFAULT.env \
#                --type xsuaa --credential                 # client_credentials
#   npx mcp-auth --service-key ./sk.json --output ./DEFAULT.env \
#                --type xsuaa --browser auto               # authorization_code
# After that the CALM_UAA_* block above can be removed — auth-broker reads
# tokens from ./DEFAULT.env.
