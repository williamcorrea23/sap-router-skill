# SAP S/4HANA credentials — used by all four skills in this collection.
#
# Setup:
#   1. Copy this file: `cp .env.example .env` (in the project where you'll invoke the skills)
#   2. Fill in values for the ONE auth mode you're using
#   3. NEVER commit .env — it's gitignored
#
# The skills read .env from the calling project's root (the cwd when you invoke the skill).
# If you don't have a project, you can also export these as env vars before invoking.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required for every mode ──────────────────────────────────────────────
SAP_HOST=https://my<tenant-id>-api.s4hana.cloud.sap   # Cloud Public Edition: include `-api` suffix
SAP_CLIENT=100                                          # SAP client number (typically 100 for prod, 200 for dev)
SAP_AUTH_MODE=basic                                     # one of: basic | cc | oauth

# ─── Mode A: basic (Cloud Public Edition with communication user) ─────────
# Use when:
#   - Your tenant is SAP S/4HANA Cloud Public Edition (my<id>.s4hana.cloud.sap)
#   - You created a Communication User (Maintain Communication User app) with a password
#   - That user is attached to the relevant Communication Arrangement (e.g. SAP_COM_0057 for invoices)
SAP_USERNAME=<your-comm-user-name>                      # e.g. COMM_USER_01, INTEGRATION_USER
SAP_PASSWORD=<your-comm-user-password>                  # keep quoted if it contains special chars: SAP_PASSWORD="abc#def"

# ─── Mode B: cc (on-prem / private edition, OAuth client credentials) ─────
# Use when:
#   - Your tenant is S/4HANA Cloud Private Edition or on-prem
#   - You have an OAuth 2.0 client (client_id + client_secret) configured for the technical user
SAP_TOKEN_URL=https://<your-host>/sap/bc/sec/oauth2/token?sap-client=100
SAP_CLIENT_ID=<your-oauth-client-id>
SAP_CLIENT_SECRET=<your-oauth-client-secret>

# ─── Mode C: oauth (Cloud Public, per-request bearer from named-user flow) ─
# Use when:
#   - You want to use YOUR named user's authorizations rather than a comm user
#   - You'll obtain a bearer token via interactive Auth Code + PKCE flow
# No long-lived secrets in .env for this mode — the bearer arrives at runtime via header.

# ─── Probe target (recommended) ───────────────────────────────────────────
# A PO/line to use for the preflight probe. Pick any existing PO line that isn't fully invoiced.
PROBE_PO=4500000000
PROBE_ITEM=10
