# SAP AI Core configuration
# Copy this file to .env and replace with real values

# Mock mode (set to 'true' for local development without AI Core credentials)
AI_CORE_MOCK=true

# AI Core connection
AI_CORE_BASE_URL=https://api.ai.REGION.aws.ml.hana.ondemand.com/v2
AI_CORE_DEPLOYMENT_ID=your-deployment-id
SAP_AI_CORE_CLIENT_ID=your-client-id
SAP_AI_CORE_CLIENT_SECRET=your-client-secret
SAP_AI_CORE_AUTH_URL=https://YOUR_SUBDOMAIN.authentication.REGION.hana.ondemand.com/oauth/token
SAP_AI_CORE_RESOURCE_GROUP=default
