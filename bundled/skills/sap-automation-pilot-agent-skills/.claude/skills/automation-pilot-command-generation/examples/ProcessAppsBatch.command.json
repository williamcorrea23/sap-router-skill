{
  "id": "examples-<<<TENANT_ID>>>:ProcessAppsBatch:1",
  "catalog": "examples-<<<TENANT_ID>>>",
  "name": "ProcessAppsBatch",
  "description": "Example: Batch processing with ForEach - list apps and process each in parallel batches",
  "version": 1,
  "inputKeys": {
    "region": {
      "type": "string",
      "sensitive": false,
      "required": true,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "The technical name of the Cloud Foundry region. Example: cf-eu10, cf-eu10-002"
    },
    "user": {
      "type": "string",
      "sensitive": false,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "The name of a technical user or an OAuth 2.0 client ID to be used for authentication. Related input keys: 'password' or 'tokenUrl'"
    },
    "password": {
      "type": "string",
      "sensitive": true,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "The password for the specified technical user or the client secret for the specified OAuth 2.0 client ID to be used for authentication. Related input keys: 'user' or 'tokenUrl'"
    },
    "refreshToken": {
      "type": "string",
      "sensitive": true,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "An OAuth 2.0 refresh token to be used for authentication. If 'refreshToken' is passed, 'user' and 'password' will be ignored. Related input keys: 'clientId', 'clientSecret', 'tokenUrl'"
    },
    "spaceId": {
      "type": "string",
      "sensitive": false,
      "required": true,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "Space GUID to list apps from"
    },
    "batchSize": {
      "type": "number",
      "sensitive": false,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": 1,
      "maxValue": 10,
      "defaultValue": "5",
      "defaultValueFromInput": null,
      "description": "Number of apps to process in parallel"
    }
  },
  "outputKeys": {
    "processedCount": {
      "type": "number",
      "sensitive": false,
      "description": "Number of apps processed"
    },
    "results": {
      "type": "array",
      "sensitive": false,
      "description": "Processing results for each app"
    }
  },
  "configuration": {
    "values": [
      {
        "alias": "regionData",
        "valueFrom": {
          "inputReference": "metadata-sapcp:CfRegionData:1",
          "inputKey": "$(.execution.input.region)"
        }
      }
    ],
    "output": {
      "processedCount": "$(.processApps.output.outputs | length)",
      "results": "$(.processApps.output.outputs)"
    },
    "executors": [
      {
        "execute": "http-sapcp:HttpRequest:1",
        "input": {
          "url": "$(.regionData.cfApiUrl)/v3/apps?space_guids=$(.execution.input.spaceId | toUrlEncoded)",
          "method": "GET",
          "headers": "{\"Accept\": \"application/json\"}",
          "user": "$(.execution.input.user)",
          "password": "$(.execution.input.password)",
          "refreshToken": "$(.execution.input.refreshToken)",
          "tokenUrl": "$(.regionData.uaaTokenUrl)",
          "clientId": "cf",
          "timeout": "30"
        },
        "alias": "listApps",
        "description": null,
        "progressMessage": "Listing applications in space...",
        "initialDelay": null,
        "pause": null,
        "when": null,
        "validate": {
          "semantic": "OR",
          "conditions": [
            {
              "semantic": "OR",
              "cases": [
                {
                  "expression": "$(.listApps.output.status)",
                  "operator": "EQUALS",
                  "semantic": "OR",
                  "values": ["200"]
                }
              ]
            }
          ]
        },
        "autoRetry": {
          "maxCount": 3,
          "delay": "5s",
          "logic": "INCREMENTAL",
          "applyOnValidation": false,
          "when": {
            "semantic": "OR",
            "conditions": [
              {
                "semantic": "OR",
                "cases": [
                  {
                    "expression": "$([408, 429, 500, 502, 503, 504, -1] | filter(. == $.listApps.output.status) | length)",
                    "operator": "EQUALS",
                    "semantic": "OR",
                    "values": ["1"]
                  }
                ]
              }
            ]
          }
        },
        "repeat": null,
        "errorMessages": [],
        "dryRun": null
      },
      {
        "execute": "utils-sapcp:ForEach:2",
        "input": {
          "command": "examples-<<<TENANT_ID>>>:ProcessSingleApp:1",
          "inputs": "$(.listApps.output.body | toObject.resources | map({appGuid: .guid, appName: .name}) | toMinifiedJsonString | toArray)",
          "defaultValues": "{}",
          "batchSize": "$(.execution.input.batchSize)"
        },
        "alias": "processApps",
        "description": null,
        "progressMessage": "Processing apps with batch size $(.execution.input.batchSize)...",
        "initialDelay": null,
        "pause": null,
        "when": {
          "semantic": "OR",
          "conditions": [
            {
              "semantic": "OR",
              "cases": [
                {
                  "expression": "$(.listApps.output.body | toObject.pagination.total_results)",
                  "operator": "NOT_EQUALS",
                  "semantic": "OR",
                  "values": ["0"]
                }
              ]
            }
          ]
        },
        "validate": null,
        "autoRetry": null,
        "repeat": null,
        "errorMessages": [],
        "dryRun": null
      }
    ],
    "listeners": []
  },
  "tags": {}
}
