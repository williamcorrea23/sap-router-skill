{
  "id": "examples-<<<TENANT_ID>>>:WaitForOperation:1",
  "catalog": "examples-<<<TENANT_ID>>>",
  "name": "WaitForOperation",
  "description": "Example: Polling pattern - wait for async operation to complete with unconditional initialDelay",
  "version": 1,
  "inputKeys": {
    "region": {
      "type": "string",
      "sensitive": false,
      "required": true,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "The technical name of the Cloud Foundry region. Example: cf-eu10, cf-eu10-002"
    },
    "user": {
      "type": "string",
      "sensitive": false,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "The name of a technical user or an OAuth 2.0 client ID to be used for authentication. Related input keys: 'password' or 'tokenUrl'"
    },
    "password": {
      "type": "string",
      "sensitive": true,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "The password for the specified technical user or the client secret for the specified OAuth 2.0 client ID to be used for authentication. Related input keys: 'user' or 'tokenUrl'"
    },
    "refreshToken": {
      "type": "string",
      "sensitive": true,
      "required": false,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "An OAuth 2.0 refresh token to be used for authentication. If 'refreshToken' is passed, 'user' and 'password' will be ignored. Related input keys: 'clientId', 'clientSecret', 'tokenUrl'"
    },
    "jobId": {
      "type": "string",
      "sensitive": false,
      "required": true,
      "minSize": null,
      "maxSize": null,
      "minValue": null,
      "maxValue": null,
      "defaultValue": null,
      "defaultValueFromInput": null,
      "description": "ID of the async job to monitor"
    }
  },
  "outputKeys": {
    "finalState": {
      "type": "string",
      "sensitive": false,
      "description": "Final state of the operation"
    },
    "result": {
      "type": "object",
      "sensitive": false,
      "description": "Full job result object"
    }
  },
  "configuration": {
    "values": [
      {
        "alias": "regionData",
        "valueFrom": {
          "inputReference": "metadata-sapcp:CfRegionData:1",
          "inputKey": "$(.execution.input.region)"
        }
      }
    ],
    "output": {
      "finalState": "$(.checkJob.output.body | toObject.state)",
      "result": "$(.checkJob.output.body | toObject)"
    },
    "executors": [
      {
        "execute": "http-sapcp:HttpRequest:1",
        "input": {
          "url": "$(.regionData.cfApiUrl)/v3/jobs/$(.execution.input.jobId | toUrlEncoded)",
          "method": "GET",
          "headers": "{\"Accept\": \"application/json\"}",
          "user": "$(.execution.input.user)",
          "password": "$(.execution.input.password)",
          "refreshToken": "$(.execution.input.refreshToken)",
          "tokenUrl": "$(.regionData.uaaTokenUrl)",
          "clientId": "cf",
          "timeout": "20"
        },
        "alias": "checkJob",
        "description": null,
        "progressMessage": "Checking job status...",
        "initialDelay": {
          "interval": "30s",
          "when": null
        },
        "pause": null,
        "when": null,
        "validate": null,
        "autoRetry": {
          "maxCount": 3,
          "delay": "5s",
          "logic": "INCREMENTAL",
          "applyOnValidation": false,
          "when": {
            "semantic": "OR",
            "conditions": [
              {
                "semantic": "OR",
                "cases": [
                  {
                    "expression": "$([408, 429, 500, 502, 503, 504, -1] | filter(. == $.checkJob.output.status) | length)",
                    "operator": "EQUALS",
                    "semantic": "OR",
                    "values": ["1"]
                  }
                ]
              }
            ]
          }
        },
        "repeat": {
          "maxCount": 60,
          "delay": "15s",
          "failOnMaxCount": true,
          "until": {
            "semantic": "OR",
            "conditions": [
              {
                "semantic": "OR",
                "cases": [
                  {
                    "expression": "$(.checkJob.output.body | toObject.state)",
                    "operator": "EQUALS",
                    "semantic": "OR",
                    "values": ["COMPLETE", "SUCCEEDED"]
                  }
                ]
              }
            ]
          }
        },
        "errorMessages": [
          {
            "message": "Job failed: $(.checkJob.output.body | toObject.errors[0].detail)",
            "when": {
              "semantic": "OR",
              "conditions": [
                {
                  "semantic": "OR",
                  "cases": [
                    {
                      "expression": "$(.checkJob.output.body | toObject.state)",
                      "operator": "EQUALS",
                      "semantic": "OR",
                      "values": ["FAILED"]
                    }
                  ]
                }
              ]
            }
          }
        ],
        "dryRun": null
      }
    ],
    "listeners": []
  },
  "tags": {}
}
