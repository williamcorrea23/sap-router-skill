# SAP CLI 配置文件示例
# 使用方法:
#   1. 复制此文件为 .env.sapcli
#   2. 修改为你的实际连接信息
#   3. 在PowerShell中运行: Get-Content .env.sapcli | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }
#   4. 或者在CMD中运行: for /f "tokens=1,2 delims==" %i in (.env.sapcli) do @set %i=%j

# ============================================
# SAP 连接配置
# ============================================

# SAP应用服务器地址 (IP或域名)
SAP_ASHOST=your-sap-host.example.com

# SAP系统实例编号 (默认00)
SAP_SYSNR=00

# SAP客户端编号 (带前导零)
SAP_CLIENT=001

# SAP登录用户名
SAP_USER=YOUR_USERNAME

# SAP登录密码
SAP_PASSWORD=your-password-here

# HTTP端口 (HTTP=8000, HTTPS=443)
SAP_PORT=8000

# 是否使用SSL (yes/no)
SAP_SSL=no

# 是否跳过SSL证书验证 (yes/no) - 开发环境使用
SAP_SSL_VERIFY=no

# 语言设置 (zh=中文, en=英文)
SAP_LANGUAGE=zh

# ============================================
# 可选配置
# ============================================

# 传输请求号 (默认值)
# SAP_CORRNR=

# 日志级别 (CRITICAL=50, ERROR=40, WARNING=30, INFO=20, DEBUG=10)
SAPCLI_LOG_LEVEL=20

# HTTP请求超时时间(秒)
SAPCLI_HTTP_TIMEOUT=900

# ABAP用户临时密码 (修改密码时使用)
SAPCLI_ABAP_USER_DUMMY_PASSWORD=DummyPwd123!
