# SAP STO 订单创建配置文件
# cp .env.example .env，然后填入实际值

# ========== SAP 共用连接配置 ==========

# OData 服务地址 (必填) — 用于创建 STO 采购订单
# 格式: http://<hostname>:<port>  常见端口: 8000 (HTTP), 44300 (HTTPS)
SAP_URL=http://<your-sap-host>:<port>

# JCo 应用服务器 (必填) — 用于创建外向交货单 (售后工厂发货时)
SAP_ASHOST=<your-sap-application-server-host>

# JCo 系统编号 (必填，如: 00)
SAP_SYSNR=00

# 客户端 / 用户名 / 密码 / 语言 — OData 和 JCo 共用同一 SAP 系统账号
SAP_CLIENT=800
SAP_USER=<your-username>
SAP_PASSWORD=<your-password>
SAP_LANG=EN

# ========== 可选配置 ==========

# SAP 路由器字符串 (可选，格式: /H/<router>/S/<port>/H/<target>)
# SAP_SAPROUTER=/H/10.0.0.1/S/3299/H/192.168.1.100

# JCo 本地库路径 (可选) — 默认自动按平台选取 scripts/lib/java/lib/<platform>/
# SAP_JCO_LIB_PATH=/usr/local/sapjco

# 日志级别 (可选，默认: CRITICAL = 完全静默)
# 仅影响诊断日志 (stderr)，不影响 preview/create 的 JSON 结果输出
#   CRITICAL — 完全静默，无任何诊断输出（默认）
#   ERROR    — 仅输出错误，如 OData 请求失败、Java 执行异常
#   WARNING  — 输出警告 + 错误，如物料单位回退、外向交货单创建失败
#   INFO     — 输出关键流程节点，如客户端初始化、交货单创建成功
#   DEBUG    — 输出所有调试信息，包括 Java 原始输出，排查问题时使用
# SAP_STO_LOG_LEVEL=CRITICAL
