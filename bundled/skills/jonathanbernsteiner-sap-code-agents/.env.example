# Copy to .env.local and fill in. Never commit .env.local.

# Anthropic API — agent loop (Sonnet), summary pass (Haiku)
ANTHROPIC_API_KEY=

# Supabase (Postgres) — service role key is server-side only, never exposed to the client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Public base URL used to build auth redirect/invite links.
# Optional locally (defaults to http://localhost:3000); set for hosted deployments.
# On Vercel it falls back to VERCEL_URL automatically if unset.
NEXT_PUBLIC_SITE_URL=
