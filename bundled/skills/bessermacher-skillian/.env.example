# Application
ENV=development
DEBUG=true

# LLM Provider: ollama | anthropic | openai | custom_openai
LLM_PROVIDER=ollama

# Ollama (local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Anthropic (production)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Custom OpenAI-compatible provider (optional)
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=https://your-api-endpoint.com/v1
CUSTOM_OPENAI_MODEL=your-model
CUSTOM_OPENAI_TIMEOUT=60
CUSTOM_OPENAI_MAX_RETRIES=3

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://skillian:skillian@localhost:5432/skillian
VECTOR_COLLECTION_NAME=skillian_knowledge

# Business Database (SAP BW mock data)
BUSINESS_DATABASE_URL=postgresql://business:business@localhost:5433/business_db

# SAP Datasphere (hdbcli connection)
# Host: your-tenant.hana.prod-eu10.hanacloud.ondemand.com
DATASPHERE_HOST=
DATASPHERE_PORT=443
DATASPHERE_SPACE=BW2AI
# User format: DBUSER#YOUR_SPACE (created in Datasphere Space Management)
DATASPHERE_USER=
DATASPHERE_PASSWORD=
DATASPHERE_ENCRYPT=true
DATASPHERE_SSL_VALIDATE_CERTIFICATE=true
DATASPHERE_TIMEOUT=60
DATASPHERE_POOL_SIZE=4
