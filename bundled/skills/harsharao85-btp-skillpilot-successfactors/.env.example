# SkillPilot Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Port for the RAG service (default: 4005)
PORT=4005

# Production note:
# In SAP BTP production, replace ANTHROPIC_API_KEY with SAP AI Core credentials.
# SAP Generative AI Hub uses the same Claude Sonnet model via XSUAA token exchange:
#   AICORE_SERVICE_KEY=<json from BTP service binding>
#   AICORE_RESOURCE_GROUP=default
#   AICORE_DEPLOYMENT_ID=<your deployment ID>
