  "arrow_optional": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;dashPattern=1 4;strokeColor=#475E75;endSize=4;startSize=4;strokeWidth=1.5;",

  "arrow_auth": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;strokeColor=#188918;endSize=4;startSize=4;strokeWidth=1.5;",

  "arrow_scim": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;strokeColor=#5D36FF;endSize=4;startSize=4;strokeWidth=1.5;",

  "arrow_trust": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;startArrow=blockThin;endFill=1;startFill=1;strokeColor=#CC00DC;endSize=4;startSize=4;strokeWidth=1.5;",

