  "tile_external_non_sap": "rounded=1;whiteSpace=wrap;html=1;strokeColor=#475E75;strokeWidth=1.5;arcSize=14;fillColor=#F5F6F7;perimeterSpacing=0;absoluteArcSize=1;",

  "tile_app_client": "rounded=1;whiteSpace=wrap;html=1;strokeColor=#475E75;strokeWidth=1.5;arcSize=14;fillColor=#F5F6F7;perimeterSpacing=0;absoluteArcSize=1;",

