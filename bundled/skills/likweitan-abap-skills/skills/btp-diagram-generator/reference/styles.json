  "text_label": "text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Helvetica;fontColor=#1D2D3E;",

  "text_label_center": "text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Helvetica;fontColor=#1D2D3E;",

  "arrow_std": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;strokeColor=#475E75;endSize=4;startSize=4;strokeWidth=1.5;",

  "arrow_dblhd": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;startArrow=blockThin;endFill=1;startFill=1;strokeColor=#475E75;endSize=4;startSize=4;strokeWidth=1.5;",

