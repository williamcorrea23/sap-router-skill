# SAP Web GUI URL (optional — can also be derived from systems.json host)
SAP_URL=https://your-sap-server/sap/bc/gui/sap/its/webgui

# SAP system credentials are configured in ~/.config/sap-mcp/systems.json
# (or set SAP_CONFIG_FILE to point to a different location).
# See: https://github.com/Hochfrequenz/sap-mcp-config

# Browser configuration (optional)
# Default is connect mode: expects Chrome running with --remote-debugging-port=9222
# CDP_URL=http://localhost:9222
# Uncomment to use Playwright-managed browser instead (requires `playwright install`):
# BROWSER_MODE=launch
# BROWSER_HEADLESS=false

# GitHub integration
# GITHUB_PAT is used for two things:
#   1. Feedback: creating GitHub issues via log_feedback (needs 'issues' scope on GITHUB_REPO)
#   2. abapGit: authenticating pulls from private repos (needs 'repo' scope on your ABAP repos)
# If you only set GITHUB_PAT, it is used for both.
# Generate token at: https://github.com/settings/tokens
GITHUB_USER=your-github-username
GITHUB_PAT=ghp_your_token_here
# GITHUB_REPO=Hochfrequenz/sapgui.mcp

# Optional: separate PAT for abapGit only (overrides GITHUB_PAT for pulls).
# Use this if you want different scopes for abapGit vs feedback/issues.
# ABAPGIT_PAT=ghp_your_abapgit_token_here

# Papertrail logging (optional)
# Disabled by default. Uncomment and fill in your Papertrail destination to enable:
# PAPERTRAIL_HOST=logsN.papertrailapp.com
# PAPERTRAIL_PORT=12345

# Audit logging (optional)
# AUDIT_LOG_DIR=/path/to/audit/logs
