# SAP credentials for agentic connections via sap_connect.
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.
#
# These are resolved server-side — passwords never appear in
# MCP tool parameters, client logs, or audit logs.

# SAP_USER=AGENT01
# SAP_PASSWORD=
# SAP_CLIENT=100
# SAP_LANGUAGE=EN
